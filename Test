-- Creates quick action buttons with proper layout
local UIFactory = {}

--- Create a quick action button
--- @param parent GuiObject -- Parent frame
--- @param index number -- Button index in grid
--- @param label string -- Button label text
--- @param callback function -- Click callback
--- @param activeColor Color3? -- Color when active
--- @param inactiveColor Color3? -- Color when inactive
--- @return TextButton
function UIFactory:createQuickActionButton(parent, index, label, callback, activeColor, inactiveColor)
    local buttonSize = CONFIG.MobileMinCellSize
    local padding = 4
    local buttonsPerRow = 3 -- 3 buttons per row for compact layout
    
    local row = math.floor((index - 1) / buttonsPerRow)
    local col = (index - 1) % buttonsPerRow
    
    local xOffset = col * (buttonSize + padding) + padding
    local yOffset = row * (buttonSize + padding) + padding
    
    local button = Instance.new("TextButton")
    button.Name = "QuickAction_" .. label
    button.Size = UDim2.new(0, buttonSize, 0, buttonSize)
    button.Position = UDim2.new(0, xOffset, 0, yOffset)
    button.BackgroundColor3 = inactiveColor or Color3.fromRGB(46, 46, 47)
    button.TextColor3 = Color3.fromRGB(255, 255, 255)
    button.Text = label
    button.Font = Enum.Font.GothamBold
    button.TextSize = 12
    button.TextWrapped = true
    button.Parent = parent
    
    -- Add corner radius
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 4)
    corner.Parent = button
    
    -- Add stroke
    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(100, 100, 100)
    stroke.Thickness = 1
    stroke.Parent = button
    
    -- Button hover effects
    registerConnection(button.MouseEnter:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.1), {
            BackgroundColor3 = activeColor or Color3.fromRGB(70, 70, 80)
        }):Play()
    end))
    
    registerConnection(button.MouseLeave:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.1), {
            BackgroundColor3 = inactiveColor or Color3.fromRGB(46, 46, 47)
        }):Play()
    end))
    
    -- Click handler
    registerConnection(button.MouseButton1Click:Connect(function()
        callback()
    end))
    
    return button
end

