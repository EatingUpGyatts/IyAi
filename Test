--// 5. COMMAND EXECUTION ENGINE (v1.3.4 - ESP FIX)
--// ============================================
local CommandExecutor = {}

--- Execute an IY command string
--- @param commandString string -- Command like ";fling" or ";esp"
function CommandExecutor:execute(commandString)
    if not commandString or commandString == "" then
        ErrorHandler:report("CommandExecutor", "Empty command string", "warning")
        return false
    end
    
    -- Strip leading semicolon if present
    local cmd = commandString:gsub("^;", ""):lower()
    
    -- Emit execution event
    EventBus:emit("COMMAND_EXECUTING", cmd)
    
    -- Try to execute via IY's global command system
    if _G.Commands then
        local success, result = pcall(function()
            -- IY executes commands via GetCommand or direct execution
            if type(_G.Commands[cmd]) == "function" then
                return _G.Commands[cmd]()
            elseif _G.executeCommand then
                return _G.executeCommand(cmd)
            end
        end)
        
        if success then
            EventBus:emit("COMMAND_EXECUTED", cmd)
            SoundManager:play("Success")
            return true
        end
    end
    
    -- Fallback: execute as lua if permitted
    if type(_G.execute) == "function" then
        local success, result = pcall(function()
            return _G.execute(cmd)
        end)
        
        if success then
            EventBus:emit("COMMAND_EXECUTED", cmd)
            SoundManager:play("Success")
            return true
        else
            ErrorHandler:report("CommandExecutor", "Failed to execute: " .. cmd, "error")
            EventBus:emit("COMMAND_FAILED", cmd)
            SoundManager:play("Error")
            return false
        end
    end
    
    ErrorHandler:report("CommandExecutor", "No command executor found", "warning")
    return false
end

-- Listen for command execution events
EventBus:on("EXECUTE_COMMAND", function(command)
    CommandExecutor:execute(command)
end)

